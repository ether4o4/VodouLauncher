<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme -->
    <style name="Theme.VodouLauncher" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your theme here -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        
        <!-- Status bar -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        
        <!-- Window properties -->
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
        
        <!-- Text appearance -->
        <item name="android:textColor">@color/white</item>
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">@color/whiteTrans80</item>
        
        <!-- Background -->
        <item name="android:background">@android:color/transparent</item>
    </style>

    <!-- Futuristic Glass Theme -->
    <style name="Theme.VodouLauncher.Glass" parent="Theme.VodouLauncher">
        <!-- Glass surface colors -->
        <item name="colorSurface">@color/glass_dark_surface_translucent</item>
        <item name="colorOnSurface">@color/text_on_glass_dark</item>
        <item name="colorPrimary">@color/futuristic_cyan</item>
        <item name="colorPrimaryVariant">@color/futuristic_cyan_dark</item>
        <item name="colorSecondary">@color/futuristic_purple</item>
        <item name="colorSecondaryVariant">@color/futuristic_teal</item>
        
        <!-- Glass effects -->
        <item name="android:windowBackground">@drawable/glass_background</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowContentOverlay">@null</item>
        
        <!-- Text on glass -->
        <item name="android:textColor">@color/text_on_glass_dark</item>
        <item name="android:textColorPrimary">@color/text_on_glass_dark</item>
        <item name="android:textColorSecondary">@color/text_on_glass_dark</item>
        <item name="android:textColorHint">@color/glass_disabled_text</item>
        
        <!-- Button styles -->
        <item name="materialButtonStyle">@style/Widget.VodouLauncher.GlassButton</item>
        <item name="borderlessButtonStyle">@style/Widget.VodouLauncher.GlassBorderlessButton</item>
        
        <!-- Card styles -->
        <item name="materialCardViewStyle">@style/Widget.VodouLauncher.GlassCard</item>
        
        <!-- Dialog styles -->
        <item name="android:dialogTheme">@style/Theme.VodouLauncher.Glass.Dialog</item>
        <item name="android:alertDialogTheme">@style/Theme.VodouLauncher.Glass.Dialog.Alert</item>
    </style>

    <!-- Glass Button -->
    <style name="Widget.VodouLauncher.GlassButton" parent="Widget.Material3.Button">
        <item name="android:background">@drawable/glass_button_background</item>
        <item name="android:textColor">@color/text_on_glass_dark</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="cornerRadius">24dp</item>
        <item name="elevation">2dp</item>
    </style>

    <!-- Glass Borderless Button -->
    <style name="Widget.VodouLauncher.GlassBorderlessButton" parent="Widget.Material3.Button.TextButton">
        <item name="android:background">@drawable/glass_borderless_button</item>
        <item name="android:textColor">@color/futuristic_cyan</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
    </style>

    <!-- Glass Card -->
    <style name="Widget.VodouLauncher.GlassCard" parent="Widget.Material3.CardView">
        <item name="cardBackgroundColor">@color/glass_card_dark</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
        <item name="strokeColor">@color/glass_border_dark</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Glass Dialog Theme -->
    <style name="Theme.VodouLauncher.Glass.Dialog" parent="ThemeOverlay.Material3.Dialog">
        <item name="android:windowBackground">@drawable/glass_dialog_background</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.6</item>
        <item name="colorSurface">@color/glass_card_dark</item>
        <item name="colorOnSurface">@color/text_on_glass_dark</item>
    </style>

    <!-- Glass Alert Dialog -->
    <style name="Theme.VodouLauncher.Glass.Dialog.Alert" parent="ThemeOverlay.Material3.Dialog.Alert">
        <item name="android:windowBackground">@drawable/glass_dialog_background</item>
        <item name="colorSurface">@color/glass_card_dark</item>
        <item name="colorOnSurface">@color/text_on_glass_dark</item>
    </style>

    <!-- Glass App Theme (for activities) -->
    <style name="Theme.VodouLauncher.Glass.App" parent="Theme.VodouLauncher.Glass">
        <item name="android:windowAnimationStyle">@style/Animation.VodouLauncher.Glass</item>
    </style>

    <!-- Glass Animations -->
    <style name="Animation.VodouLauncher.Glass" parent="@android:style/Animation">
        <item name="android:windowEnterAnimation">@anim/glass_fade_in</item>
        <item name="android:windowExitAnimation">@anim/glass_fade_out</item>
        <item name="android:activityOpenEnterAnimation">@anim/glass_slide_in_right</item>
        <item name="android:activityOpenExitAnimation">@anim/glass_slide_out_left</item>
        <item name="android:activityCloseEnterAnimation">@anim/glass_slide_in_left</item>
        <item name="android:activityCloseExitAnimation">@anim/glass_slide_out_right</item>
    </style>

    <!-- Light Glass Theme -->
    <style name="Theme.VodouLauncher.Glass.Light" parent="Theme.VodouLauncher.Glass">
        <item name="colorSurface">@color/glass_light_surface_translucent</item>
        <item name="colorOnSurface">@color/text_on_glass_light</item>
        <item name="android:textColor">@color/text_on_glass_light</item>
        <item name="android:textColorPrimary">@color/text_on_glass_light</item>
        <item name="android:textColorSecondary">@color/text_on_glass_light</item>
    </style>

    <!-- Cyan Accent Theme -->
    <style name="Theme.VodouLauncher.Glass.Cyan" parent="Theme.VodouLauncher.Glass">
        <item name="colorPrimary">@color/futuristic_cyan</item>
        <item name="colorPrimaryVariant">@color/futuristic_cyan_light</item>
        <item name="colorSecondary">@color/futuristic_teal</item>
        <item name="android:windowBackground">@drawable/glass_background_cyan</item>
    </style>

    <!-- Purple Accent Theme -->
    <style name="Theme.VodouLauncher.Glass.Purple" parent="Theme.VodouLauncher.Glass">
        <item name="colorPrimary">@color/futuristic_purple</item>
        <item name="colorSecondary">@color/futuristic_cyan</item>
        <item name="android:windowBackground">@drawable/glass_background_purple</item>
    </style>
</resources>