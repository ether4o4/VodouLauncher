<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Vista Evolved Theme - Familiar Vista feeling but futuristic and modern -->
    
    <!-- Base Vista Evolved Theme -->
    <style name="Theme.VodouLauncher.VistaEvolved" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Vista Color Scheme (Evolved) -->
        <item name="colorPrimary">@color/vista_evolved_blue</item>
        <item name="colorPrimaryVariant">@color/vista_evolved_blue_dark</item>
        <item name="colorSecondary">@color/vista_evolved_silver</item>
        <item name="colorSecondaryVariant">@color/vista_evolved_silver_dark</item>
        <item name="colorSurface">@color/vista_surface_dark</item>
        <item name="colorOnSurface">@color/vista_text_primary</item>
        <item name="colorBackground">@android:color/transparent</item>
        
        <!-- Vista Window Properties -->
        <item name="android:windowBackground">@drawable/vista_window_background</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
        
        <!-- Vista Status/Navigation Bar -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        
        <!-- Vista Text Appearance -->
        <item name="android:textColor">@color/vista_text_primary</item>
        <item name="android:textColorPrimary">@color/vista_text_primary</item>
        <item name="android:textColorSecondary">@color/vista_text_secondary</item>
        <item name="android:textColorHint">@color/vista_text_disabled</item>
        
        <!-- Vista Typography -->
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif</item>
        
        <!-- Vista Button Styles -->
        <item name="materialButtonStyle">@style/Widget.VodouLauncher.VistaButton</item>
        <item name="borderlessButtonStyle">@style/Widget.VodouLauncher.VistaBorderlessButton</item>
        
        <!-- Vista Card Style -->
        <item name="materialCardViewStyle">@style/Widget.VodouLauncher.VistaCard</item>
        
        <!-- Vista Dialog Styles -->
        <item name="android:dialogTheme">@style/Theme.VodouLauncher.VistaEvolved.Dialog</item>
        <item name="android:alertDialogTheme">@style/Theme.VodouLauncher.VistaEvolved.Dialog.Alert</item>
        
        <!-- Vista Animation -->
        <item name="android:windowAnimationStyle">@style/Animation.VodouLauncher.Vista</item>
        
        <!-- Vista Elevation/Shadows -->
        <item name="android:elevation">8dp</item>
        
        <!-- Vista Ripple Effect -->
        <item name="android:selectableItemBackground">@drawable/vista_ripple</item>
        <item name="android:selectableItemBackgroundBorderless">@drawable/vista_ripple_borderless</item>
    </style>
    
    <!-- Vista Button -->
    <style name="Widget.VodouLauncher.VistaButton" parent="Widget.Material3.Button">
        <item name="android:background">@drawable/vista_button_background</item>
        <item name="android:textColor">@color/vista_text_primary</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="cornerRadius">24dp</item>
        <item name="elevation">4dp</item>
        <item name="android:stateListAnimator">@animator/vista_button_state</item>
    </style>
    
    <!-- Vista Borderless Button -->
    <style name="Widget.VodouLauncher.VistaBorderlessButton" parent="Widget.Material3.Button.TextButton">
        <item name="android:background">@drawable/vista_borderless_button</item>
        <item name="android:textColor">@color/vista_evolved_blue_light</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="elevation">0dp</item>
    </style>
    
    <!-- Vista Card -->
    <style name="Widget.VodouLauncher.VistaCard" parent="Widget.Material3.CardView">
        <item name="cardBackgroundColor">@color/vista_card_dark</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">8dp</item>
        <item name="strokeColor">@color/vista_border_light</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardPreventCornerOverlap">false</item>
        <item name="cardUseCompatPadding">true</item>
    </style>
    
    <!-- Vista Dialog Theme -->
    <style name="Theme.VodouLauncher.VistaEvolved.Dialog" parent="ThemeOverlay.Material3.Dialog">
        <item name="android:windowBackground">@drawable/vista_dialog_background</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.6</item>
        <item name="colorSurface">@color/vista_card_dark</item>
        <item name="colorOnSurface">@color/vista_text_primary</item>
        <item name="android:windowAnimationStyle">@style/Animation.VodouLauncher.Vista.Dialog</item>
    </style>
    
    <!-- Vista Alert Dialog -->
    <style name="Theme.VodouLauncher.VistaEvolved.Dialog.Alert" parent="ThemeOverlay.Material3.Dialog.Alert">
        <item name="android:windowBackground">@drawable/vista_dialog_background</item>
        <item name="colorSurface">@color/vista_card_dark</item>
        <item name="colorOnSurface">@color/vista_text_primary</item>
    </style>
    
    <!-- Vista Animations -->
    <style name="Animation.VodouLauncher.Vista" parent="@android:style/Animation">
        <item name="android:windowEnterAnimation">@anim/vista_fade_in</item>
        <item name="android:windowExitAnimation">@anim/vista_fade_out</item>
        <item name="android:activityOpenEnterAnimation">@anim/vista_slide_in_right</item>
        <item name="android:activityOpenExitAnimation">@anim/vista_slide_out_left</item>
        <item name="android:activityCloseEnterAnimation">@anim/vista_slide_in_left</item>
        <item name="android:activityCloseExitAnimation">@anim/vista_slide_out_right</item>
        <item name="android:taskOpenEnterAnimation">@anim/vista_scale_in</item>
        <item name="android:taskOpenExitAnimation">@anim/vista_scale_out</item>
        <item name="android:taskCloseEnterAnimation">@anim/vista_scale_in</item>
        <item name="android:taskCloseExitAnimation">@anim/vista_scale_out</item>
    </style>
    
    <!-- Vista Dialog Animations -->
    <style name="Animation.VodouLauncher.Vista.Dialog" parent="@android:style/Animation.Dialog">
        <item name="android:windowEnterAnimation">@anim/vista_dialog_enter</item>
        <item name="android:windowExitAnimation">@anim/vista_dialog_exit</item>
    </style>
    
    <!-- Vista Light Theme -->
    <style name="Theme.VodouLauncher.VistaEvolved.Light" parent="Theme.VodouLauncher.VistaEvolved">
        <item name="colorSurface">@color/vista_surface_light</item>
        <item name="colorOnSurface">@color/vista_uhd_black</item>
        <item name="android:textColor">@color/vista_uhd_black</item>
        <item name="android:textColorPrimary">@color/vista_uhd_black</item>
        <item name="android:textColorSecondary">@color/vista_uhd_gray</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>
    
    <!-- Vista Blue Theme (Classic Vista) -->
    <style name="Theme.VodouLauncher.VistaEvolved.Blue" parent="Theme.VodouLauncher.VistaEvolved">
        <item name="colorPrimary">@color/vista_evolved_blue</item>
        <item name="colorPrimaryVariant">@color/vista_evolved_blue_dark</item>
        <item name="colorSecondary">@color/vista_evolved_silver</item>
        <item name="android:windowBackground">@drawable/vista_blue_window_background</item>
    </style>
    
    <!-- Vista Silver Theme -->
    <style name="Theme.VodouLauncher.VistaEvolved.Silver" parent="Theme.VodouLauncher.VistaEvolved">
        <item name="colorPrimary">@color/vista_evolved_silver</item>
        <item name="colorPrimaryVariant">@color/vista_evolved_silver_dark</item>
        <item name="colorSecondary">@color/vista_evolved_blue</item>
        <item name="android:windowBackground">@drawable/vista_silver_window_background</item>
    </style>
    
    <!-- Vista Black Theme -->
    <style name="Theme.VodouLauncher.VistaEvolved.Black" parent="Theme.VodouLauncher.VistaEvolved">
        <item name="colorPrimary">@color/vista_evolved_black</item>
        <item name="colorPrimaryVariant">@color/vista_evolved_black_dark</item>
        <item name="colorSecondary">@color/vista_evolved_blue_light</item>
        <item name="android:windowBackground">@drawable/vista_black_window_background</item>
    </style>
    
    <!-- Vista Aero Theme (True Vista Glass) -->
    <style name="Theme.VodouLauncher.VistaEvolved.Aero" parent="Theme.VodouLauncher.VistaEvolved">
        <item name="colorPrimary">@color/vista_aero_blue</item>
        <item name="colorSurface">@color/vista_glass_clear</item>
        <item name="android:windowBackground">@drawable/vista_aero_background</item>
        <item name="android:windowIsFloating">true</item>
    </style>
    
    <!-- Vista Modern Theme (Futuristic Evolution) -->
    <style name="Theme.VodouLauncher.VistaEvolved.Modern" parent="Theme.VodouLauncher.VistaEvolved">
        <item name="colorPrimary">@color/vista_modern_cyan</item>
        <item name="colorSecondary">@color/vista_modern_magenta</item>
        <item name="colorPrimaryVariant">@color/vista_modern_teal</item>
        <item name="android:windowBackground">@drawable/vista_modern_background</item>
        <item name="android:windowAnimationStyle">@style/Animation.VodouLauncher.Vista.Modern</item>
    </style>
    
    <!-- Vista Modern Animations -->
    <style name="Animation.VodouLauncher.Vista.Modern" parent="Animation.VodouLauncher.Vista">
        <item name="android:windowEnterAnimation">@anim/vista_modern_enter</item>
        <item name="android:windowExitAnimation">@anim/vista_modern_exit</item>
        <item name="android:activityOpenEnterAnimation">@anim/vista_modern_slide_in</item>
        <item name="android:activityOpenExitAnimation">@anim/vista_modern_slide_out</item>
    </style>
    
    <!-- Vista Taskbar Style -->
    <style name="Widget.VodouLauncher.VistaTaskbar" parent="android:Widget">
        <item name="android:background">@drawable/vista_taskbar_background</item>
        <item name="android:minHeight">56dp</item>
        <item name="android:paddingStart">8dp</item>
        <item name="android:paddingEnd">8dp</item>
    </style>
    
    <!-- Vista Start Menu Style -->
    <style name="Widget.VodouLauncher.VistaStartMenu" parent="android:Widget">
        <item name="android:background">@drawable/vista_start_menu_background</item>
        <item name="android:minWidth">320dp</item>
        <item name="android:minHeight">480dp</item>
        <item name="android:elevation">24dp</item>
    </style>
    
    <!-- Vista Window Style -->
    <style name="Widget.VodouLauncher.VistaWindow" parent="android:Widget">
        <item name="android:background">@drawable/vista_window_frame</item>
        <item name="android:minWidth">240dp</item>
        <item name="android:minHeight">160dp</item>
        <item name="android:elevation">16dp</item>
    </style>
    
    <!-- Vista Title Bar Style -->
    <style name="Widget.VodouLauncher.VistaTitleBar" parent="android:Widget">
        <item name="android:background">@drawable/vista_titlebar_background</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
    </style>
    
    <!-- Vista Icon Style -->
    <style name="Widget.VodouLauncher.VistaIcon" parent="android:Widget">
        <item name="android:background">@drawable/vista_icon_background</item>
        <item name="android:minWidth">64dp</item>
        <item name="android:minHeight">64dp</item>
        <item name="android:padding">8dp</item>
    </style>
    
    <!-- Vista Notification Style -->
    <style name="Widget.VodouLauncher.VistaNotification" parent="android:Widget">
        <item name="android:background">@drawable/vista_notification_background</item>
        <item name="android:minWidth">280dp</item>
        <item name="android:minHeight">80dp</item>
        <item name="android:elevation">12dp</item>
        <item name="android:padding">16dp</item>
    </style>
    
    <!-- Vista Tooltip Style -->
    <style name="Widget.VodouLauncher.VistaTooltip" parent="android:Widget">
        <item name="android:background">@drawable/vista_tooltip_background</item>
        <item name="android:minWidth">120dp</item>
        <item name="android:minHeight">40dp</item>
        <item name="android:elevation">8dp</item>
        <item name="android:padding">8dp</item>
    </style>
    
    <!-- Vista Progress Bar Style -->
    <style name="Widget.VodouLauncher.VistaProgressBar" parent="android:Widget.ProgressBar">
        <item name="android:progressDrawable">@drawable/vista_progress_bar</item>
        <item name="android:indeterminateDrawable">@drawable/vista_progress_indeterminate</item>
        <item name="android:minHeight">4dp</item>
        <item name="android:maxHeight">4dp</item>
    </style>
    
    <!-- Vista Seek Bar Style -->
    <style name="Widget.VodouLauncher.VistaSeekBar" parent="android:Widget.SeekBar">
        <item name="android:progressDrawable">@drawable/vista_seek_bar</item>
        <item name="android:thumb">@drawable/vista_seek_thumb</item>
        <item name="android:splitTrack">false</item>
    </style>
    
    <!-- Vista Switch Style -->
    <style name="Widget.VodouLauncher.VistaSwitch" parent="android:Widget.CompoundButton.Switch">
        <item name="android:track">@drawable/vista_switch_track</item>
        <item name="android:thumb">@drawable/vista_switch_thumb</item>
    </style>
    
    <!-- Vista Checkbox Style -->
    <style name="Widget.VodouLauncher.VistaCheckbox" parent="android:Widget.CompoundButton.CheckBox">
        <item name="android:button">@drawable/vista_checkbox</item>
    </style>
    
    <!-- Vista Radio Button Style -->
    <style name="Widget.VodouLauncher.VistaRadioButton" parent="android:Widget.CompoundButton.RadioButton">
        <item name="android:button">@drawable/vista_radio_button</item>
    </style>
</resources>