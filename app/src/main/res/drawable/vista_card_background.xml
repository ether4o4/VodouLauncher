<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Shadow layer (for elevation) -->
    <item
        android:left="2dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="2dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/vista_shadow_medium" />
            <corners android:radius="12dp" />
        </shape>
    </item>
    
    <!-- Main glass card -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="@color/vista_card_dark"
                android:endColor="@color/vista_transparent_70"
                android:angle="135" />
            <stroke
                android:width="1dp"
                android:color="@color/vista_border_light" />
            <corners android:radius="12dp" />
        </shape>
    </item>
    
    <!-- Top glass reflection -->
    <item
        android:top="0dp"
        android:left="0dp"
        android:right="0dp"
        android:height="4dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="@color/vista_reflection_top"
                android:endColor="@android:color/transparent"
                android:angle="90" />
            <corners
                android:topLeftRadius="12dp"
                android:topRightRadius="12dp"
                android:bottomLeftRadius="0dp"
                android:bottomRightRadius="0dp" />
        </shape>
    </item>
    
    <!-- Left glass reflection -->
    <item
        android:top="0dp"
        android:left="0dp"
        android:bottom="0dp"
        android:width="4dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="@color/vista_reflection_top"
                android:endColor="@android:color/transparent"
                android:angle="0" />
            <corners
                android:topLeftRadius="12dp"
                android:bottomLeftRadius="12dp"
                android:topRightRadius="0dp"
                android:bottomRightRadius="0dp" />
        </shape>
    </item>
    
    <!-- Inner glow effect -->
    <item
        android:top="2dp"
        android:left="2dp"
        android:right="2dp"
        android:bottom="2dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="@color/vista_glow_inner"
                android:endColor="@android:color/transparent"
                android:angle="0"
                android:centerX="0.5"
                android:centerY="0.5"
                android:gradientRadius="40%" />
            <corners android:radius="10dp" />
        </shape>
    </item>
    
    <!-- Blue accent corners -->
    <item
        android:top="1dp"
        android:left="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <stroke
                android:width="1dp"
                android:color="@color/vista_glow_blue" />
            <corners android:radius="11dp" />
        </shape>
    </item>
</layer-list>